# ── Supabase (public — safe to expose in browser) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Lemon Squeezy (public — checkout URL) ──────────────────────────────────────
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/your-product-id

# ── OAuth Redirect ──────────────────────────────────────────────────────────────
# In Supabase Dashboard → Auth → URL Configuration, add:
#   http://localhost:3000/dashboard
#   https://yourdomain.com/dashboard
