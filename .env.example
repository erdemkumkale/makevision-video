# ── Frontend (Vercel Environment Variables) ────────────────────────────────────
# NEXT_PUBLIC_ ile başlayanlar tarayıcıda da görünür — güvenli, kasıtlı
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase Edge Functions (Supabase Secrets) ─────────────────────────────────
# Supabase dashboard → Edge Functions → Secrets bölümünden girilir
PIAPI_API_KEY=          # piapi.ai → API Keys
SHOTSTACK_API_KEY=      # shotstack.io → API Key (Stage veya Production)
GEMINI_API_KEY=         # aistudio.google.com → API Keys

# ── Supabase servis anahtarları (otomatik gelir, elle girme) ───────────────────
# SUPABASE_URL              → otomatik
# SUPABASE_ANON_KEY         → otomatik
# SUPABASE_SERVICE_ROLE_KEY → otomatik
